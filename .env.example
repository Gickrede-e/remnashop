# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gickvpn?schema=public
POSTGRES_DB=gickvpn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Auth
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32 # REPLACE BEFORE PRODUCTION
ADMIN_EMAILS=admin@example.com
ADMIN_INITIAL_PASSWORD=

# Site
NEXT_PUBLIC_SITE_URL=https://vpn.example.com
NEXT_PUBLIC_SITE_NAME=GickShop
SITE_ADDRESS=vpn.example.com

# Docker images
APP_IMAGE=gickrede/remnashop:latest

# Telegram
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=

# Remnawave
REMNAWAVE_BASE_URL=https://your-panel.example.com
REMNAWAVE_API_TOKEN=REPLACE_WITH_REMNAWAVE_API_TOKEN # REPLACE BEFORE PRODUCTION

# YooKassa
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=REPLACE_WITH_YOOKASSA_SECRET_KEY # REPLACE BEFORE PRODUCTION
YOOKASSA_WEBHOOK_SECRET=REPLACE_WITH_YOOKASSA_WEBHOOK_SECRET # REPLACE BEFORE PRODUCTION
YOOKASSA_ALLOWED_IPS=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11,77.75.156.35,77.75.154.128/25,2a02:5180::/32

# Platega.io
PLATEGA_API_KEY=REPLACE_WITH_PLATEGA_API_KEY # REPLACE BEFORE PRODUCTION
PLATEGA_MERCHANT_ID=
PLATEGA_WEBHOOK_SECRET=REPLACE_WITH_PLATEGA_WEBHOOK_SECRET # REPLACE BEFORE PRODUCTION

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD # REPLACE BEFORE PRODUCTION
EMAIL_FROM="GickShop <notifications@example.com>"

# Referral system
REFERRAL_REWARD_TYPE=FREE_DAYS
REFERRAL_REWARD_VALUE=3

# Cron
CRON_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_16 # REPLACE BEFORE PRODUCTION
